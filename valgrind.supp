}

# --- libtasn1 (GLFW init): possibly lost ---
{
   tasn1_possibly_lost
   Memcheck:Leak
   match-leak-kinds: possible
   ...
   obj:/usr/lib/x86_64-linux-gnu/libtasn1.so*
}

# --- Vulkan loader: possibly lost (vkEnumeratePhysicalDevices) ---
{
   vulkan_loader_possibly_lost
   Memcheck:Leak
   match-leak-kinds: possible
   ...
   obj:/usr/lib/x86_64-linux-gnu/libvulkan.so*
}

# --- Other GPU drivers loaded during enumeration (asahi, lvp, etc.) ---
{
   vulkan_asahi_possibly_lost
   Memcheck:Leak
   match-leak-kinds: possible
   ...
   obj:/usr/lib/x86_64-linux-gnu/libvulkan_asahi.so*
}
{
   vulkan_lvp_possibly_lost
   Memcheck:Leak
   match-leak-kinds: possible
   ...
   obj:/usr/lib/x86_64-linux-gnu/libvulkan_lvp.so*
}
{
   vulkan_intel_possibly_lost
   Memcheck:Leak
   match-leak-kinds: possible
   ...
   obj:/usr/lib/x86_64-linux-gnu/libvulkan_intel.so*
}
{
   vulkan_nouveau_possibly_lost
   Memcheck:Leak
   match-leak-kinds: possible
   ...
   obj:/usr/lib/x86_64-linux-gnu/libvulkan_nouveau.so*
}

# --- libstdc++ locale init: possibly lost ---
{
   stdcpp_possibly_lost
   Memcheck:Leak
   match-leak-kinds: possible
   ...
   obj:/usr/lib/x86_64-linux-gnu/libstdc++.so*
}
